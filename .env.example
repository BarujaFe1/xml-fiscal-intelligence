# XML Fiscal Intelligence — environment template
# Copy to .env.local and fill values. Never commit real secrets or fiscal XMLs.

# --- Supabase (optional for MVP local filesystem mode) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# --- Storage ---
STORAGE_BUCKET_XML=xml-batches

# --- App limits ---
MAX_UPLOAD_MB=50
NEXT_PUBLIC_MAX_UPLOAD_MB=50

# --- External parser (future FastAPI split) ---
PARSER_API_URL=

# --- Privacy / demo ---
ENABLE_DEMO_MODE=true
ENABLE_MASKING=true

# --- Deploy ---
VERCEL_PROJECT_NAME=xml-fiscal-intelligence

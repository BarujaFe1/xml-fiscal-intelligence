# XML Fiscal Intelligence — environment template
# Copy to .env.local and fill values. Never commit real secrets, certificates, or fiscal XMLs.

# --- Supabase (optional for MVP local filesystem / IndexedDB mode) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# --- Storage ---
STORAGE_BUCKET_XML=xml-batches
STORAGE_PROVIDER=local

# --- App limits ---
MAX_UPLOAD_MB=50
NEXT_PUBLIC_MAX_UPLOAD_MB=50
IMPORT_PARALLELISM=4

# --- External parser (future FastAPI / worker split) ---
PARSER_API_URL=

# --- Privacy / demo ---
ENABLE_DEMO_MODE=true
ENABLE_MASKING=true
ENABLE_DATA_MASKING=true

# --- AI / RAG (optional; default mock, never send real fiscal data without consent) ---
ENABLE_AI=false
AI_PROVIDER=mock
OPENAI_API_KEY=
XAI_API_KEY=

# --- XSD / signature validation (schemas under schemas/ when configured) ---
ENABLE_XSD_VALIDATION=false
XSD_SCHEMA_DIR=./schemas
ENABLE_XML_SIGNATURE_VALIDATION=false

# --- DuckDB analytics (optional / local) ---
ENABLE_DUCKDB=false
DUCKDB_PATH=./private-data/analytics.duckdb

# --- Deploy ---
VERCEL_PROJECT_NAME=xml-fiscal-intelligence

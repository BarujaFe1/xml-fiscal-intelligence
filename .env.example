# XML Fiscal Intelligence — environment template
# Copy to .env.local. Never commit secrets, certificates, or real fiscal XMLs.

# --- Supabase Auth / DB ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# --- Billing (mock | stripe) ---
BILLING_PROVIDER=mock
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Optional catalog (test mode — see docs/BILLING_ARCHITECTURE.md)
# STRIPE_PRICE_ESSENCIAL=price_1Ts3QuK9MwFwrKToE5x2mOPt
# STRIPE_PRICE_PROFISSIONAL=price_1Ts3QyK9MwFwrKTo9PYpcAGD
# STRIPE_PRICE_ESCRITORIO=price_1Ts3QzK9MwFwrKTovncqSWpH

# --- Storage ---
STORAGE_BUCKET_XML=xml-batches
# local | supabase (supabase requires service role + private bucket)
STORAGE_PROVIDER=local
LOCAL_STORAGE_ROOT=./private-data/storage

# --- App limits ---
MAX_UPLOAD_MB=50
NEXT_PUBLIC_MAX_UPLOAD_MB=50
IMPORT_PARALLELISM=4

# --- Privacy / demo ---
ENABLE_DEMO_MODE=true
ENABLE_MASKING=true
ENABLE_DATA_MASKING=true
ENABLE_PRIVACY_MODE=true

# --- AI (optional; never send raw XML without consent) ---
ENABLE_AI=false
NEXT_PUBLIC_ENABLE_AI=false
AI_PROVIDER=mock
OPENAI_API_KEY=
XAI_API_KEY=

# --- Billing readiness (client-safe flag; never put secrets here) ---
NEXT_PUBLIC_BILLING_READY=false

# --- Feature flags (server-evaluated for protected resources) ---
FEATURE_CLOUD_PROCESSING=false
NEXT_PUBLIC_FEATURE_CLOUD_PROCESSING=false
FEATURE_CNPJ_ALPHANUMERIC_STRICT=true
FEATURE_RTC_PARSING=true
FEATURE_EFD_GENERATION=true
FEATURE_ADVANCED_AUDIT=true
FEATURE_NEW_NAVIGATION=true

# --- Validation ---
ENABLE_XSD_VALIDATION=false
XSD_SCHEMA_DIR=./schemas
ENABLE_XML_SIGNATURE_VALIDATION=false

# --- Analytics ---
ENABLE_DUCKDB=false
DUCKDB_PATH=./private-data/analytics.duckdb

# --- Deploy ---
VERCEL_PROJECT_NAME=xml-fiscal-intelligence

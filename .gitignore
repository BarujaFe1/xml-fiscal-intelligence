# dependencies
node_modules
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage
playwright-report
test-results

# next.js
.next/
out/
build
dist

# env & secrets
.env
.env*.local
.env.production

# local data & real fiscal XMLs — NEVER commit
data/**
!data/.gitkeep
private-test-data/**
!private-test-data/README.md
private-data/**
!private-data/README.md
private-imports/**
!private-imports/README.md
private-exports/**
!private-exports/README.md
private-certificates/**
!private-certificates/README.md
*.zip
!samples/**/*.xml
*.pfx
*.p12
*.cer
*.crt
*.key

# real XML dumps outside samples
**/real-xml/**
**/xml-reais/**

# debug / OS
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.DS_Store
Thumbs.db
*.pem

# generated UI-capture evidence (PNGs are regenerated by `npm run screenshots:all`)
artifacts/ui-capture/after/*.png
artifacts/server.out.log
artifacts/server.err.log

# typescript
next-env.d.ts
*.tsbuildinfo

# vercel
.vercel

# IDE
.idea
.vscode
*.swp

# personal prompt artifacts (apresentação, pesquisa) — não são código do projeto
prompts-*.md

# real per-company EFD outputs (CNPJ-named) — never commit real fiscal data
docs/pva/**/efd-*.txt
**/companies-summary.csv
**/erros.csv
**/pva-raw/
# real NFe inputs (real fiscal XMLs, 300 CNPJs) — never commit raw data
docs/pva/**/inputs/
# handoff docs may contain leaked secrets — keep out of git
docs/pva/**/HANDOFF*.md

# allow sanitized validation evidence + synthetic demo fixtures
!docs/pva/**/*.sanitized.json
!docs/pva/**/*.sanitized.txt
!docs/pva/**/README.md
!docs/pva/**/PVA_RESULT*.md
!docs/pva/**/efd-generated-2.txt
